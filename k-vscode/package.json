{
  "name": "k-language",
  "displayName": "k language",
  "description": "Syntax highlighting and snippets for the k language — first-order partial functions over algebraic data types",
  "publisher": "wojtek",
  "version": "0.2.0",
  "license": "ISC",
  "homepage": "https://github.com/fraczak/k",
  "repository": {
    "type": "git",
    "url": "https://github.com/fraczak/k.git"
  },
  "keywords": [
    "k",
    "algebraic",
    "partial functions",
    "ADT",
    "types"
  ],
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "k",
        "aliases": [
          "k language",
          "k"
        ],
        "extensions": [
          ".k"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "k",
        "scopeName": "source.k",
        "path": "./syntaxes/k.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "k",
        "path": "./snippets/k.json"
      }
    ]
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1"
  }
}
