{
  "comments": {
    "lineComment": "--",
    "blockComment": ["/*", "*/"]
  },
  "brackets": [
    ["{", "}"],
    ["(", ")"],
    ["<", ">"]
  ],
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "(", "close": ")" },
    { "open": "<", "close": ">" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "/*", "close": "*/" }
  ],
  "surroundingPairs": [
    ["{", "}"],
    ["(", ")"],
    ["<", ">"],
    ["\"", "\""],
    ["'", "'"]
  ],
  "wordPattern": "[a-zA-Z0-9_+\\-][a-zA-Z0-9_?!+\\-]*",
  "indentationRules": {
    "increaseIndentPattern": "[{(<]\\s*$",
    "decreaseIndentPattern": "^\\s*[})>]"
  },
  "onEnterRules": [
    {
      "beforeText": "/\\*.*\\*/$",
      "action": { "indent": "none" }
    },
    {
      "beforeText": "/\\*",
      "afterText": "\\*/",
      "action": { "indent": "indentOutdent" }
    }
  ]
}
