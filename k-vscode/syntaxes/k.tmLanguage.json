{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "k",
  "scopeName": "source.k",
  "patterns": [
    { "include": "#comment-block" },
    { "include": "#comment-line" },
    { "include": "#type-definition" },
    { "include": "#function-definition" },
    { "include": "#filter" },
    { "include": "#type-ref" },
    { "include": "#canonical-ref" },
    { "include": "#projection-dot" },
    { "include": "#projection-slash" },
    { "include": "#variant-intro" },
    { "include": "#string-double" },
    { "include": "#string-single" },
    { "include": "#dots" },
    { "include": "#operators" },
    { "include": "#brackets" }
  ],
  "repository": {

    "comment-block": {
      "name": "comment.block.k",
      "begin": "/\\*",
      "end": "\\*/",
      "beginCaptures": { "0": { "name": "punctuation.definition.comment.k" } },
      "endCaptures":   { "0": { "name": "punctuation.definition.comment.k" } }
    },

    "comment-line": {
      "name": "comment.line.k",
      "match": "(?://|--|%|#).*$"
    },

    "type-definition": {
      "comment": "$ name = ... ; — defines a named code (type)",
      "match": "(\\$)\\s*([a-zA-Z0-9_+\\-][a-zA-Z0-9_?!+\\-]*)(?=\\s*=)",
      "captures": {
        "1": { "name": "keyword.operator.type.k" },
        "2": { "name": "entity.name.type.k" }
      }
    },

    "function-definition": {
      "comment": "name = ... ; — top-level function/relation definition",
      "match": "^\\s*([a-zA-Z_][a-zA-Z0-9_?!+\\-]*)\\s*(?==)",
      "captures": {
        "1": { "name": "entity.name.function.k" }
      }
    },

    "filter": {
      "comment": "? introduces a filter/pattern constraint: ?<...>=X, ?{...}=X",
      "patterns": [
        {
          "comment": "filter union ?< ... > = X",
          "begin": "(\\?)\\s*(<)",
          "end": "(>)(?:\\s*(=)\\s*([a-zA-Z0-9_?!+\\-]+))?",
          "beginCaptures": {
            "1": { "name": "keyword.operator.filter.k" },
            "2": { "name": "punctuation.brackets.k" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.brackets.k" },
            "2": { "name": "keyword.operator.filter.k" },
            "3": { "name": "variable.other.pattern.k" }
          },
          "patterns": [
            { "include": "#comment-block" },
            { "include": "#comment-line" },
            { "include": "#filter" },
            { "include": "#pattern-variable" },
            { "include": "#type-ref" },
            { "include": "#string-double" },
            { "include": "#string-single" },
            { "include": "#dots" },
            { "include": "#operators" },
            { "include": "#brackets" }
          ]
        },
        {
          "comment": "filter product ?{ ... } = X",
          "begin": "(\\?)\\s*(\\{)",
          "end": "(\\})(?:\\s*(=)\\s*([a-zA-Z0-9_?!+\\-]+))?",
          "beginCaptures": {
            "1": { "name": "keyword.operator.filter.k" },
            "2": { "name": "punctuation.brackets.k" }
          },
          "endCaptures": {
            "1": { "name": "punctuation.brackets.k" },
            "2": { "name": "keyword.operator.filter.k" },
            "3": { "name": "variable.other.pattern.k" }
          },
          "patterns": [
            { "include": "#comment-block" },
            { "include": "#comment-line" },
            { "include": "#filter" },
            { "include": "#pattern-variable" },
            { "include": "#type-ref" },
            { "include": "#string-double" },
            { "include": "#string-single" },
            { "include": "#dots" },
            { "include": "#operators" },
            { "include": "#brackets" }
          ]
        }
      ]
    },

    "pattern-variable": {
      "comment": "Uppercase identifiers used as pattern variables inside filter expressions",
      "name": "variable.other.pattern.k",
      "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
    },

    "type-ref": {
      "comment": "$name — use of a named code as a type annotation or type expression",
      "match": "(\\$)([a-zA-Z0-9_+\\-][a-zA-Z0-9_?!+\\-]*)?",
      "captures": {
        "1": { "name": "keyword.operator.type.k" },
        "2": { "name": "storage.type.k" }
      }
    },

    "canonical-ref": {
      "comment": "@base58hash — content-addressed canonical code reference",
      "name": "variable.other.constant.k",
      "match": "@[a-zA-Z0-9]+"
    },

    "projection-dot": {
      "comment": ".label or .\"label\" — product field projection",
      "patterns": [
        {
          "name": "keyword.operator.projection.k",
          "match": "\\.(?:[a-zA-Z0-9_+\\-][a-zA-Z0-9_?!+\\-]*)"
        },
        {
          "begin": "\\.(\")",
          "end": "\"",
          "beginCaptures": { "0": { "name": "keyword.operator.projection.k" } },
          "endCaptures":   { "0": { "name": "keyword.operator.projection.k" } },
          "contentName": "string.quoted.double.k"
        },
        {
          "begin": "\\.(\')",
          "end": "\'",
          "beginCaptures": { "0": { "name": "keyword.operator.projection.k" } },
          "endCaptures":   { "0": { "name": "keyword.operator.projection.k" } },
          "contentName": "string.quoted.single.k"
        }
      ]
    },

    "projection-slash": {
      "comment": "/tag or /\"tag\" — union tag projection (assert and unwrap)",
      "patterns": [
        {
          "name": "keyword.operator.projection.k",
          "match": "/(?:[a-zA-Z0-9_+\\-][a-zA-Z0-9_?!+\\-]*)"
        },
        {
          "begin": "/(\")",
          "end": "\"",
          "beginCaptures": { "0": { "name": "keyword.operator.projection.k" } },
          "endCaptures":   { "0": { "name": "keyword.operator.projection.k" } },
          "contentName": "string.quoted.double.k"
        },
        {
          "begin": "/(\')",
          "end": "\'",
          "beginCaptures": { "0": { "name": "keyword.operator.projection.k" } },
          "endCaptures":   { "0": { "name": "keyword.operator.projection.k" } },
          "contentName": "string.quoted.single.k"
        }
      ]
    },

    "variant-intro": {
      "comment": "|tag or |\"tag\" — variant (tagged union) introduction",
      "patterns": [
        {
          "name": "keyword.operator.intro.k",
          "match": "\\|[a-zA-Z0-9_+\\-][a-zA-Z0-9_?!+\\-]*"
        },
        {
          "begin": "\\|(\")",
          "end": "\"",
          "beginCaptures": { "0": { "name": "keyword.operator.intro.k" } },
          "endCaptures":   { "0": { "name": "keyword.operator.intro.k" } },
          "contentName": "string.quoted.double.k"
        },
        {
          "begin": "\\|(\')",
          "end": "\'",
          "beginCaptures": { "0": { "name": "keyword.operator.intro.k" } },
          "endCaptures":   { "0": { "name": "keyword.operator.intro.k" } },
          "contentName": "string.quoted.single.k"
        }
      ]
    },

    "string-double": {
      "name": "string.quoted.double.k",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "name": "constant.character.escape.k", "match": "\\\\(?:[\"\\\\/bfnrt]|u[0-9a-fA-F]{4})" },
        { "name": "invalid.illegal.escape.k",    "match": "\\\\." }
      ]
    },

    "string-single": {
      "name": "string.quoted.single.k",
      "begin": "'",
      "end": "'",
      "patterns": [
        { "name": "constant.character.escape.k", "match": "\\\\(?:['\\\\/bfnrt]|u[0-9a-fA-F]{4})" },
        { "name": "invalid.illegal.escape.k",    "match": "\\\\." }
      ]
    },

    "dots": {
      "comment": "... — the any/open pattern (unconstrained position)",
      "name": "constant.language.k",
      "match": "\\.\\.\\."
    },

    "operators": {
      "comment": "= ; , : ~ — structural separators and definition operators",
      "name": "punctuation.separator.k",
      "match": "[=;,:]|~"
    },

    "brackets": {
      "comment": "{ } ( ) < > — grouping and combinator delimiters",
      "name": "punctuation.brackets.k",
      "match": "[{}()<>]"
    }
  }
}
